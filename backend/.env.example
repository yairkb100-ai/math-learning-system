# Copy to .env and fill in values (local dev). In production set these as
# environment variables on the host (Railway).

# JWT signing secret — MUST be a long random string in production.
SECRET_KEY=change-me-in-production

# Postgres connection string. Leave unset locally to use the bundled SQLite file.
# Railway's Postgres plugin exposes this automatically as ${{ Postgres.DATABASE_URL }}.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Comma-separated list of allowed frontend origins for CORS (production domain).
# CORS_ORIGINS=https://math-learning.vercel.app

# Initial admin password created by seed.py (defaults to admin123 if unset).
# ADMIN_PASSWORD=choose-a-strong-password

# Directory for uploaded files. In production point this at a persistent
# Railway volume mount (e.g. /data/uploads) so uploads survive redeploys.
# UPLOAD_DIR=/data/uploads
